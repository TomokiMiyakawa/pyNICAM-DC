# pyNICAM-DC production performance preset (JAX / GPU fast path)
#
# The device-resident + kernel-fusion optimizations are gated by PYNICAM_* env
# flags, ALL default-OFF (so a plain run reproduces the reference path). Source this
# file to enable the full validated stack before launching the JAX backend:
#
#     source config/production.env
#     mpiexec -n <N> python3 -u pynicamdc/nhm/driver/driver-dc.py --driver-setting <settings>.toml
#
# Requires the JAX backend (backend="jax" in driversettings.toml). For the fp32 path
# (~1.8x faster, ~half GPU memory) set precision="float32" there as well.
# Validated bit-exact/at-floor: JW gold 1.15e-11, DCMIP tracer 3e-15.

# --- runtime (GPU: 1 rank per GPU, CUDA-aware MPI) ---
export JAX_PLATFORMS=cuda            # use 'cpu' to run the same stack on CPU (testing)
export MPI4JAX_USE_CUDA_MPI=1        # on-device halo exchange over CUDA-aware MPI
export HCOLL_ENABLE=0

# --- GPU memory: on-demand pool capped at 0.5 of device memory ---
# Measured (gl09 fp32, GH200 96 GB): live working set ~29 GiB; the allocator otherwise grows
# lazily to ~64 GiB at the default cap. 0.5 (~48 GiB) is speed-neutral (per-step unchanged) and
# keeps a safety margin above the measured OOM floor (~0.45 works, 0.40 OOMs). Adjust as needed:
# raise toward 0.9 for a larger case that needs more headroom; lower toward ~0.45 ONLY after
# validating a full-length run (0.45 has no margin -> hard OOM crash on fragmentation variance).
export XLA_PYTHON_CLIENT_PREALLOCATE=false
export XLA_PYTHON_CLIENT_MEM_FRACTION=0.5

# --- kernel fusion (jit whole segments / the per-nl loop / the tracer) ---
export PYNICAM_FUSE_PREPOST=1
export PYNICAM_FUSE_NLBODY=1
export PYNICAM_FUSE_NLSCAN=1
export PYNICAM_FUSE_TRACER=1
export PYNICAM_FUSE_TRACER_WARM=2

# --- cross-step device residency of the prognostic state (Phase E) ---
export PYNICAM_RESIDENT_PRGVAR=1

# --- device residency of dynamics/tracer state + on-device COMM (71 flags) ---
export PYNICAM_RESIDENT_PREPOST=1
export PYNICAM_RESIDENT_ADVCONVMOM=1
export PYNICAM_HDIFF_RESIDENT_FULL=1
export PYNICAM_HDIFF_PACK_DEVICE=1
