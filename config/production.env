# pyNICAM-DC production performance preset (JAX / GPU fast path)
#
# The device-resident + kernel-fusion optimizations are gated by PYNICAM_* env
# flags, ALL default-OFF (so a plain run reproduces the reference path). Source this
# file to enable the full validated stack before launching the JAX backend:
#
#     source config/production.env
#     mpiexec -n <N> python3 -u pynicamdc/nhm/driver/driver-dc.py --driver-setting <settings>.toml
#
# Requires the JAX backend (backend="jax" in driversettings.toml). For the fp32 path
# (~1.8x faster, ~half GPU memory) set precision="float32" there as well.
# Validated bit-exact/at-floor: JW gold 1.15e-11, DCMIP tracer 3e-15.

# --- runtime (GPU: 1 rank per GPU, CUDA-aware MPI) ---
export JAX_PLATFORMS=cuda            # use 'cpu' to run the same stack on CPU (testing)
export MPI4JAX_USE_CUDA_MPI=1        # on-device halo exchange over CUDA-aware MPI
export HCOLL_ENABLE=0

# --- GPU memory: on-demand pool, high ceiling ---
# PREALLOCATE=false -> the BFC pool grows ON DEMAND (no upfront grab). MEM_FRACTION is left UNSET
# so the ceiling defaults to 0.75, freeing ~25% of the card for pool-EXTERNAL consumers -- NCCL /
# mpi4jax / CUDA-aware-MPI staging buffers for the device-resident halo COMM. (The old 0.9 was
# needless: the sweep showed live=28.8 GiB / OOM-floor~0.45 with per-step FLAT down to ~0.45, so a
# higher ceiling bought no speed and just held ~25 GB of unused pool that starved the collectives.)
# Raise back toward 0.9 ONLY if a larger case OOMs AND the COMM path isn't memory-starved.
# NB: XLA_PYTHON_CLIENT_MEM_FRACTION is deprecated; the current name is XLA_CLIENT_MEM_FRACTION.
export XLA_PYTHON_CLIENT_PREALLOCATE=false

# --- kernel fusion (jit whole segments / the per-nl loop / the tracer) ---

# --- cross-step device residency of the prognostic state (Phase E) ---

# --- device residency MASTER (the full-NICAM escape hatch: =0 forces the jax
# non-resident host-staged reference path, to A/B a physics bug vs its residency
# interaction). The individual RESIDENT_*/HDIFF/SINGLE_DRAIN gates are being folded
# INTO this one switch (bk.resident()); the remaining lines below are not-yet-folded. ---
export PYNICAM_RESIDENT=1
# --- device residency of dynamics/tracer state + on-device COMM (71 flags) ---
# (The DIAG w-boundary donor is now an unconditional cached zeros placeholder on the device path
# -- see Dyn._diag_donor_dev; no gate needed. The donated rows are never consumed, so it removes
# the 2 remaining full-field 340MB/step H2D with no correctness assumption.)
