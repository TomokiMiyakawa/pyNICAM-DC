# pyNICAM-DC production performance preset (JAX / GPU fast path)
#
# The device-resident + kernel-fusion optimizations are gated by PYNICAM_* env
# flags, ALL default-OFF (so a plain run reproduces the reference path). Source this
# file to enable the full validated stack before launching the JAX backend:
#
#     source config/production.env
#     mpiexec -n <N> python3 -u pynicamdc/nhm/driver/driver-dc.py --driver-setting <settings>.toml
#
# Requires the JAX backend (backend="jax" in driversettings.toml). For the fp32 path
# (~1.8x faster, ~half GPU memory) set precision="float32" there as well.
# Validated bit-exact/at-floor: JW gold 1.15e-11, DCMIP tracer 3e-15.

# --- runtime (GPU: 1 rank per GPU, CUDA-aware MPI) ---
export JAX_PLATFORMS=cuda            # use 'cpu' to run the same stack on CPU (testing)
export MPI4JAX_USE_CUDA_MPI=1        # on-device halo exchange over CUDA-aware MPI
export HCOLL_ENABLE=0

# --- GPU memory: on-demand pool, high ceiling ---
# MEM_FRACTION is a CEILING (fraction of the CARD), not a target: with PREALLOCATE=false the pool
# grows only as needed, so a high fraction wastes nothing but maximizes what fits and minimizes
# OOM risk. Lowering it does NOT let more fit (it only caps lower) -> pure downside on a dedicated
# GPU, so keep it high. 0.9 leaves headroom for the CUDA/library context (pool-external).
export XLA_PYTHON_CLIENT_PREALLOCATE=false
export XLA_PYTHON_CLIENT_MEM_FRACTION=0.9

# --- kernel fusion (jit whole segments / the per-nl loop / the tracer) ---
export PYNICAM_FUSE_PREPOST=1
export PYNICAM_FUSE_NLBODY=1
export PYNICAM_FUSE_NLSCAN=1
export PYNICAM_FUSE_TRACER=1
export PYNICAM_FUSE_TRACER_WARM=2

# --- cross-step device residency of the prognostic state (Phase E) ---
export PYNICAM_RESIDENT_PRGVAR=1

# --- device residency MASTER (the full-NICAM escape hatch: =0 forces the jax
# non-resident host-staged reference path, to A/B a physics bug vs its residency
# interaction). The individual RESIDENT_*/HDIFF/SINGLE_DRAIN gates are being folded
# INTO this one switch (bk.resident()); the remaining lines below are not-yet-folded. ---
export PYNICAM_RESIDENT=1
# --- device residency of dynamics/tracer state + on-device COMM (71 flags) ---
export PYNICAM_RESIDENT_PREPOST=1
export PYNICAM_RESIDENT_ADVCONVMOM=1
export PYNICAM_HDIFF_RESIDENT_FULL=1
export PYNICAM_RESIDENT_FORILOOP=1
export PYNICAM_RESIDENT_PROG=1
export PYNICAM_RESIDENT_DIAG=1
export PYNICAM_RESIDENT_GTEND=1
export PYNICAM_RESIDENT_PROGMEAN=1
export PYNICAM_VI_DEADDIVDAMP_GUARD=1
export PYNICAM_RESIDENT_ETHH=1
export PYNICAM_SINGLE_DRAIN=1
export PYNICAM_RESIDENT_RKCOPY=1
export PYNICAM_RESIDENT_TRACER_CKD=1
export PYNICAM_RESIDENT_TRACER_RHOG=1
export PYNICAM_RESIDENT_TRACER_HADVD=1
export PYNICAM_RESIDENT_TRACER_RHOGV=1
export PYNICAM_RESIDENT_PROGOUT=1
export PYNICAM_RESIDENT_VI_DRAINOUT=1
export PYNICAM_RESIDENT_GZTILDE=1
export PYNICAM_RESIDENT_FLUXGEOM=1
export PYNICAM_RESIDENT_TRACER_FRHOG=1
export PYNICAM_RESIDENT_TRACER_PROGQOUT=1
export PYNICAM_RESIDENT_ADVMOM_OUT=1
export PYNICAM_RESIDENT_HDIFF_TEND=1
export PYNICAM_RESIDENT_ADVMOM_OUT_PL=1
export PYNICAM_RESIDENT_HDIFF_TEND_PL=1
export PYNICAM_RESIDENT_PROGMEAN_OUT=1
export PYNICAM_RESIDENT_GTEND_PL=1
export PYNICAM_RESIDENT_TRACER_FRHOG_PL=1
export PYNICAM_RESIDENT_TRACER_VPOLE=1
export PYNICAM_RESIDENT_TRACER_PROGQOUT_PL=1
export PYNICAM_RESIDENT_HDIFF_RHOGH=1
export PYNICAM_RESIDENT_HDIFF_WK=1
export PYNICAM_RESIDENT_VI_PROGOUT_SKIP=1
export PYNICAM_RESIDENT_DIVDAMP_2D_OUT=1
export PYNICAM_RESIDENT_FTENDQ=1
export PYNICAM_RESIDENT_HADV_FLXH_SKIP=1
export PYNICAM_RESIDENT_TRACER_RHOGQIN=1
export PYNICAM_RESIDENT_VIPROGPL_SEED=1
export PYNICAM_RESIDENT_HDIFF_POLE_PACK=1
export PYNICAM_RESIDENT_ADVMOM_POLE_IN=1
export PYNICAM_RESIDENT_DIAGPL_DRAIN_SKIP=1
export PYNICAM_RESIDENT_HDIFF_TEND_POLE=1
export PYNICAM_RESIDENT_SRC_FLUX_POLE=1
export PYNICAM_RESIDENT_PROGMEAN_OUT_PL=1
export PYNICAM_RESIDENT_TRACER_RHOG_INPL=1
export PYNICAM_RESIDENT_PROG0_PL=1
export PYNICAM_RESIDENT_PREPOST_PL_IN=1
export PYNICAM_RESIDENT_DIAGPL_REST_SKIP=1
export PYNICAM_RESIDENT_DIVDAMP_POLE_IN=1
export PYNICAM_RESIDENT_HDIFF_WK_POLE=1
export PYNICAM_RESIDENT_PROGPL_DRAIN_SKIP=1
