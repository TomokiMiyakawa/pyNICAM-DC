# pyNICAM-DC — validated optimized run config for Miyabi GH200 (verified 2026-06-21)
#
# `source` this before launching a jax GPU run, and pair it with the mpirun flags
# shown at the bottom. Every setting below was verified BIT-EXACT (cmp_prec
# worst_rel 1.15e-11 at gl07, identical to the CPU numpy gold).
#
# Measured effect (gl08, pe04 / 4x GH200, per-step excl. compile):
#   baseline ................... 33.13 s/step
#   + RESIDENT_VISEG ........... 30.49  (-8.2%)
#   + FUSE_DIVDAMP_FULL (STEP-7)  29.55  (-11.0%)
#   + FUSE_REMAP (harvested) ... 26.98  (-18.6% cumulative)   f90 ratio 0.52x
# Plus GTL_max/min vectorization (always-on, no toggle): init -36 s/job.
#
# NOTE: RESIDENT_VISEG and FUSE_DIVDAMP_FULL use on-device COMM (mpi4jax). They
# need the mpi4jax CUDA-aware setup below; that is why they are kept env-gated
# (default OFF in code) rather than forced on globally.

# --- device-resident / fused kernels (jax backend only; numpy backend ignores these)
export PYNICAM_RESIDENT_VISEG=1      # VI hot segment stays device-resident across COMM
export PYNICAM_FUSE_DIVDAMP_FULL=1   # STEP-7: OPRT3D_divdamp -> on-device COMM -> post fused
export PYNICAM_FUSE_REMAP=1          # tracer MIURA remap fused kernel (kernels/horizontalremap.py)

# --- mpi4jax CUDA-aware on-device COMM (required by the two residency toggles above)
export MPI4JAX_USE_CUDA_MPI=1
export HCOLL_ENABLE=0
export MPI4JAX_NO_WARN_JAX_VERSION=1   # mpi4jax 0.9.0.post1 supports jax<=0.10.0; we run 0.10.2 (works)

# --- launch recipe (Miyabi PBS, 1 rank/GPU = 1 rank/node; from the run dir):
#   unset OMPI_MCA_mca_base_env_list
#   mpirun -n <N> --mca coll ^hcoll \
#     -x PATH -x LD_LIBRARY_PATH -x PYTHONPATH \
#     -x XLA_PYTHON_CLIENT_PREALLOCATE -x XLA_PYTHON_CLIENT_MEM_FRACTION \
#     -x PYNICAM_RESIDENT_VISEG -x PYNICAM_FUSE_DIVDAMP_FULL -x PYNICAM_FUSE_REMAP \
#     -x MPI4JAX_USE_CUDA_MPI -x HCOLL_ENABLE -x MPI4JAX_NO_WARN_JAX_VERSION \
#     python <CODE>/pynicamdc/nhm/driver/driver-dc.py --driver-setting ./driversettings.toml
